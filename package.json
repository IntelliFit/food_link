{
  "name": "food_link",
  "version": "2.0.15",
  "private": true,
  "description": "AI Food Analysis and Diet Sharing Community",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "Sass",
    "framework": "React"
  },
  "scripts": {
    "prepare": "husky",
    "new": "taro new",
    "dev:backend": "node scripts/run-backend.cjs",
    "stop:backend": "node scripts/stop-backend.cjs",
    "dev:restart": "bash scripts/restart-dev.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:backend": "cd backend && source venv/bin/activate && pytest",
    "test:backend:coverage": "cd backend && source venv/bin/activate && pytest --cov=. --cov-report=html",
    "build:weapp": "taro build --type weapp",
    "build:weapp:preview": "cross-env NODE_ENV=production TARO_APP_API_BASE_URL=https://healthymax.cn npm run build:weapp",
    "build:weapp:debug": "cross-env NODE_ENV=development TARO_APP_API_BASE_URL=https://healthymax.cn npm run build:weapp -- --no-check",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:harmony-hybrid": "taro build --type harmony-hybrid",
    "dev:weapp": "cross-env NODE_ENV=development TARO_APP_API_BASE_URL=http://127.0.0.1:3010 npm run build:weapp -- --watch --no-check",
    "dev:weapp:online": "cross-env NODE_ENV=production TARO_APP_API_BASE_URL=https://healthymax.cn npm run build:weapp -- --watch --no-check",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:harmony-hybrid": "npm run build:harmony-hybrid -- --watch",
    "iconfont": "iconfont-taro"
  },
  "browserslist": {
    "development": [
      "defaults and fully supports es6-module",
      "maintained node versions"
    ],
    "production": [
      "last 3 versions",
      "Android >= 4.1",
      "ios >= 8"
    ]
  },
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@taroify/core": "^0.8.0",
    "@taroify/icons": "^0.8.0",
    "@tarojs/components": "4.1.10",
    "@tarojs/helper": "4.1.10",
    "@tarojs/plugin-framework-react": "4.1.10",
    "@tarojs/plugin-platform-alipay": "4.1.10",
    "@tarojs/plugin-platform-h5": "4.1.10",
    "@tarojs/plugin-platform-harmony-hybrid": "4.1.10",
    "@tarojs/plugin-platform-jd": "4.1.10",
    "@tarojs/plugin-platform-qq": "4.1.10",
    "@tarojs/plugin-platform-swan": "4.1.10",
    "@tarojs/plugin-platform-tt": "4.1.10",
    "@tarojs/plugin-platform-weapp": "4.1.10",
    "@tarojs/react": "4.1.10",
    "@tarojs/runtime": "4.1.10",
    "@tarojs/shared": "4.1.10",
    "@tarojs/taro": "4.1.10",
    "@vant/area-data": "^2.1.0",
    "echarts": "^5.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "taro-plugin-canvas": "^1.0.10",
    "vant-weapp": "^0.5.29"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tarojs/cli": "4.1.10",
    "@tarojs/plugin-generator": "4.1.10",
    "@tarojs/vite-runner": "4.1.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^5",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-preset-taro": "4.1.10",
    "consola": "^3.2.3",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.1.10",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.1.2",
    "miniprogram-automator": "^0.12.1",
    "postcss": "^8.5.6",
    "react-refresh": "^0.14.0",
    "sass": "^1.75.0",
    "sharp": "^0.34.5",
    "stylelint": "^16.4.0",
    "stylelint-config-standard": "^38.0.0",
    "taro-iconfont-cli": "^3.3.0",
    "terser": "^5.30.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5",
    "vite": "^4.2.0",
    "vite-plugin-style-import": "^2.0.0"
  }
}
