PORT=3010
# DeepSeek API 配置（用于 AI 营养洞察等）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DashScope API 配置（千问模型）- 保留以备用
# 从阿里云 DashScope 控制台获取 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

APPID=your_wechat_appid_here
SECRET=your_wechat_secret_here

JWT_SECRET_KEY=your_jwt_secret_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 或者使用通用的 API_KEY 环境变量名
# API_KEY=your_api_key_here

# DashScope API 基础 URL（可选，默认使用兼容模式）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 天地图 API Key（地名搜索代理）
TIANDITU_TK=your_tianditu_api_key_here

OFOXAI_API_KEY=your_ofoxai_api_key_here

# LLM 默认模型提供商 (qwen 或 gemini)
LLM_PROVIDER=gemini

# 微信支付商户号
WECHAT_PAY_MCHID=your_merchant_id_here

# 你自己服务器的回调地址(用于给微信服务器请求)
WECHAT_PAY_NOTIFY_URL=https://healthymax.cn/api/payment/wechat/notify/membership
# 这是商户 API 证书的序列号
WECHAT_PAY_SERIAL_NO=your_cert_serial_no_here

# 你在商户平台设置的一串 32 位密钥
WECHAT_PAY_API_V3_KEY=your_api_v3_key_here

# WECHAT_PAY_PRIVATE_KEY / WECHAT_PAY_PRIVATE_KEY_PATH：商户 API 证书私钥 apiclient_key.pem
WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"

# WECHAT_PAY_PUBLIC_KEY / WECHAT_PAY_PUBLIC_KEY_PATH：微信支付公钥
WECHAT_PAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
