/* iconfont 字体定义（base64 内联，确保自定义 tab-bar 组件内可用） */
@font-face {
  font-family: "iconfont";
  src: url('data:font/truetype;charset=utf-8;base64,') format('truetype');
}

.iconfont {
  font-family: "iconfont" !important;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.icon-shouye:before { content: "\e606"; }
.icon-weibiaoti1:before { content: "\e625"; }
.icon-quanzi:before { content: "\ee17"; }
.icon-user:before { content: "\e7ae"; }
.icon-kcal:before { content: "\e831"; }


/* 底部导航栏 - 优雅下凹曲线 + 悬浮按钮 + 底部阴影 */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
  background: transparent;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding-left: 20rpx;
  padding-right: 20rpx;
  z-index: 999;
}

/* 下凹曲线背景（SVG 作为 data URI，全宽拉伸）
   参考图风格：中间按钮为旋转 45° 的圆角正方形，
   下凹两侧为 45° 斜线，与菱形按钮平行呼应，
   底部用 cubic-bezier 画圆润过渡。
   开口宽 180rpx（325~425），深度 42rpx（到 y=42）
*/
.custom-tab-bar::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100%;  
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D%27http%3A//www.w3.org/2000/svg%27%20viewBox%3D%270%200%20750%2096%27%20preserveAspectRatio%3D%27none%27%3E%3Cpath%20d%3D%27M0%2C0%20L265%2C0%20C295%2C0%20315%2C10%20330%2C30%20C345%2C44%20360%2C44%20375%2C44%20C390%2C44%20405%2C44%20420%2C30%20C435%2C10%20455%2C0%20485%2C0%20L750%2C0%20L750%2C96%20L0%2C96%20Z%27%20fill%3D%27%23ffffff%27/%3E%3C/svg%3E");
  background-size: 100% 100%;
  background-repeat: no-repeat;
  filter: drop-shadow(0 -8rpx 28rpx rgba(0, 0, 0, 0.22));
  z-index: -1;
  pointer-events: none;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 15rpx;
  transition: all 0.2s ease;
  position: relative;
  height: 110rpx;
  padding-bottom: 20rpx;
  box-sizing: border-box;
}

.tab-item.selected .tab-text {
  color: #5cb896;
  font-weight: 500;
}

.icon-wrapper {
  width: 46rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.tab-icon {
  font-size: 42rpx;
  line-height: 1;
  color: #b0b0b0;
  transition: all 0.2s ease;
}

/* 图片图标（如"我的"）兼容 */
image.tab-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.tab-item.selected .tab-icon {
  color: #5cb896;
}

.tab-item.selected .icon-wrapper {
  transform: scale(1.05);
}

/* ===== 中间记录按钮 - 旋转 45° 的圆角正方形（参考图风格） ===== */
.tab-item.center-item {
  z-index: 2;
}

.tab-item.center-item .icon-wrapper {
  width: 110rpx;
  height: 110rpx;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.center-icon-wrapper {
  width: 110rpx;
  height: 110rpx;
  background: #5cb896;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(92, 184, 150, 0.55), 0 4rpx 8rpx rgba(0, 0, 0, 0.08);
  position: absolute;
  left: 50%;
  top: 39%;
  margin-left: -55rpx;
  margin-top: -55rpx;
  transform: translateY(-18rpx);
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

.center-icon {
  font-size: 54rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1;
}

/* 我的按钮上的数字 badge */
.profile-icon-wrapper {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -14rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ef4444;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.tab-badge-text {
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

/* ===== 文字样式 ===== */
.tab-text {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1;
  transition: all 0.2s ease;
}

/* 隐藏状态 */
.custom-tab-bar.hidden {
  display: none;
}

.custom-tab-bar.hidden::before {
  display: none;
}

/* 深色主题：与页面 `fl-page-theme-root--dark` 协调 */
.custom-tab-bar--dark::before {
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D%27http%3A//www.w3.org/2000/svg%27%20viewBox%3D%270%200%20750%2096%27%20preserveAspectRatio%3D%27none%27%3E%3Cpath%20d%3D%27M0%2C0%20L265%2C0%20C295%2C0%20315%2C10%20330%2C30%20C345%2C44%20360%2C44%20375%2C44%20C390%2C44%20405%2C44%20420%2C30%20C435%2C10%20455%2C0%20485%2C0%20L750%2C0%20L750%2C96%20L0%2C96%20Z%27%20fill%3D%27%231a2220%27/%3E%3C/svg%3E");
  filter: drop-shadow(0 -8rpx 28rpx rgba(0, 0, 0, 0.45));
}

.custom-tab-bar--dark .tab-icon {
  color: #6b7280;
}

.custom-tab-bar--dark .tab-item.selected .tab-icon {
  color: #7dd3b0;
}

.custom-tab-bar--dark .tab-text {
  color: #6b7280;
}

.custom-tab-bar--dark .tab-item.selected .tab-text {
  color: #7dd3b0;
}
